# Copy this file to .local.env and edit values for your machine.
# .local.env is ignored by git.

# Bridge Excel import AI adapter. Keep "local" unless you have an external adapter.
BRIDGE_IMPORT_LLM_PROVIDER=local
BRIDGE_IMPORT_LLM_ENDPOINT=
BRIDGE_IMPORT_LLM_MODEL=
BRIDGE_IMPORT_LLM_API_KEY=

# Natural-language process setting adapter.
# Use "local" for built-in fallback, "http" for a custom adapter,
# or "openai_compatible" for public chat-completions APIs.
PROCESS_NL_LLM_PROVIDER=local
PROCESS_NL_LLM_ENDPOINT=https://api.example.com/v1/chat/completions
PROCESS_NL_LLM_MODEL=your-model
PROCESS_NL_LLM_API_KEY=
PROCESS_NL_LLM_TEMPERATURE=0
PROCESS_NL_LLM_RESPONSE_FORMAT=json_object

# Supabase PostgreSQL session pool connection string used by the backend only.
# Use the session pooler URI from Supabase Project Settings > Database.
# Keep this value server-side; do not expose it to Vite/frontend env vars.
SUPABASE_POSTGRES_SESSION_POOL_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_POSTGRES_POOL_SIZE=5
